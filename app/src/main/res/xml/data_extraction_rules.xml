<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup/transfer rules for API 31+ (A5). Exclude sensitive local state: SAF grant
  store, recents, and the thumbnail index/cache should not leave the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="filora.db" />
        <exclude domain="sharedpref" path="saf_grants.xml" />
        <exclude domain="file" path="datastore/" />
        <exclude domain="external" path="thumbnails/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="filora.db" />
        <exclude domain="sharedpref" path="saf_grants.xml" />
        <exclude domain="file" path="datastore/" />
        <exclude domain="external" path="thumbnails/" />
    </device-transfer>
</data-extraction-rules>
